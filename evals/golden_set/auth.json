{
  "$schema": "evals/golden_set/_schema.md",
  "decision_refs": ["T-17", "T-18", "T-21"],
  "description": "Critical auth scenarios — refresh token rotation, login rate limit, CSRF Origin validation.",
  "cases": [
    {
      "id": "auth-rotation-detect-theft",
      "scenario": "refresh_token rotation + 24h blacklist 도용 감지",
      "given": {
        "step1_login": "POST /auth/login {email, password}",
        "step2_first_refresh": "POST /auth/refresh (cookie A)",
        "step3_replay_old_cookie": "POST /auth/refresh (cookie A again, after rotation)"
      },
      "expected": {
        "step1": { "status": 200, "set_cookie": "refresh=B; HttpOnly; Secure; SameSite=Strict; Path=/auth", "body": { "ok": true, "data": { "access_token": "<jwt>" } } },
        "step2": { "status": 200, "set_cookie": "refresh=C; ...", "blacklisted": "B" },
        "step3": { "status": 401, "body": { "ok": false, "error": { "code": "TOKEN_REPLAY", "message": "..." } }, "session_revoked": true }
      },
      "decision": "T-18"
    },
    {
      "id": "auth-login-rate-limit",
      "scenario": "5 logins in 60s → 6th returns 429",
      "given": {
        "loop": "POST /auth/login × 6 within 60s same IP"
      },
      "expected": {
        "first_5": { "status": 200 },
        "sixth": { "status": 429, "body": { "ok": false, "error": { "code": "RATE_LIMITED", "message": "..." } } }
      },
      "decision": "T-18"
    },
    {
      "id": "auth-csrf-origin-mismatch",
      "scenario": "POST /assets without Origin header → 403",
      "given": {
        "request": "POST /assets, no Origin header"
      },
      "expected": {
        "status": 403,
        "body": { "ok": false, "error": { "code": "CSRF_ORIGIN_INVALID", "message": "..." } }
      },
      "decision": "T-17"
    },
    {
      "id": "auth-csrf-origin-mismatch-cross-site",
      "scenario": "POST /assets with foreign Origin → 403",
      "given": {
        "request": "POST /assets, Origin: https://evil.com"
      },
      "expected": {
        "status": 403,
        "body": { "ok": false, "error": { "code": "CSRF_ORIGIN_INVALID", "message": "..." } }
      },
      "decision": "T-17"
    },
    {
      "id": "auth-csrf-bypass-bearer",
      "scenario": "POST /hooks/event with Bearer token, no Origin → 200 (CSRF exempt per T-17)",
      "given": {
        "request": "POST /hooks/event, Authorization: Bearer <HOOKS_API_KEY>, no Origin"
      },
      "expected": {
        "status": 200
      },
      "decision": "T-17"
    },
    {
      "id": "auth-logout-clears-state",
      "scenario": "POST /auth/logout invalidates refresh + clears cookie",
      "given": {
        "step1": "logout",
        "step2": "POST /auth/refresh with old cookie"
      },
      "expected": {
        "step1": { "status": 200, "set_cookie": "refresh=; Max-Age=0" },
        "step2": { "status": 401 }
      },
      "decision": "T-18"
    }
  ]
}
