{
  "compilerOptions": {
    "target":            "ESNext",
    "module":            "NodeNext",
    "moduleResolution":  "NodeNext",
    "lib":               ["ESNext"],
    "outDir":            "dist",
    "rootDir":           "src",
    "strict":            true,
    "skipLibCheck":      true,
    "esModuleInterop":   true,
    "resolveJsonModule": true
  },
  "include": ["src"]
}
