{
  "name": "@team-claude/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":            "tsx --env-file=../../.env watch src/index.ts",
    "build":          "tsc",
    "start":          "node dist/index.js",
    "test":           "vitest run",
    "typecheck":      "tsc --noEmit",
    "seed":           "tsx src/scripts/seed.ts",
    "reset-password": "tsx src/scripts/reset-password.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@team-claude/db":   "workspace:*",
    "bcrypt":            "^5.1.1",
    "better-sqlite3":    "^11.0.0",
    "drizzle-orm":       "^0.38.0",
    "hono":              "^4.7.0",
    "jsonwebtoken":      "^9.0.2",
    "pino":              "^9.5.0",
    "zod":               "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt":         "^5.0.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/jsonwebtoken":   "^9.0.6",
    "@types/node":           "^22.0.0",
    "tsx":                   "^4.19.0",
    "typescript":            "^5.8.0",
    "vitest":                "^2.1.0"
  }
}
