{
  "name": "team-claude-system",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev":     "pnpm --parallel -r dev",
    "build":   "pnpm -r build",
    "migrate": "pnpm --filter @team-claude/db migrate",
    "seed":    "pnpm --filter @team-claude/db seed",
    "sync":    "pnpm --filter @team-claude/api sync"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["bcrypt", "better-sqlite3", "esbuild"]
  }
}
