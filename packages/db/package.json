{
  "name": "@team-claude/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "migrate":   "tsx src/migrate.ts",
    "generate":  "drizzle-kit generate",
    "seed":      "tsx src/seed.ts",
    "typecheck": "tsc --noEmit",
    "test":      "tsx src/schema.test.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "drizzle-orm":    "^0.38.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node":           "^22.0.0",
    "drizzle-kit":           "^0.30.0",
    "tsx":                   "^4.19.0",
    "typescript":            "^5.8.0"
  },
  "exports": {
    ".": {
      "types":   "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types":   "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./client": {
      "types":   "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./queries": {
      "types":   "./src/queries.ts",
      "default": "./src/queries.ts"
    }
  }
}
