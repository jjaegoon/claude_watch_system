# Team Claude System — environment template
# Copy to .env and fill in values. .env is git-ignored.
# 평문 시크릿은 어디에도 저장하지 않음. 운영 시 secret manager 사용.

# === Runtime ===
NODE_ENV=development
PORT=3000

# === Database ===
DATABASE_URL=./data/dev.db

# === Auth (T-17, T-18) ===
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# === CORS (T-17 — Origin 검증) ===
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# === Hooks (T-13 — wrapper script) ===
HOOKS_API_KEY=

# === Asset repo (T-25, T-45) ===
ASSETS_REPO_PATH=
# Skill 설치 명령 base URL. 미설정 시 install_command=null (UI에 관리자 문의 안내 표시).
# 예: ASSETS_REPO_URL=https://github.com/your-org/team-claude-assets
ASSETS_REPO_URL=

# === M2 활성 (D+21) ===
GITHUB_PAT=
GITHUB_WEBHOOK_SECRET=

# === M3 활성 (D+29) ===
ANTHROPIC_API_KEY=

# === M4 활성 (D+36) ===
BETTERSTACK_TOKEN=
